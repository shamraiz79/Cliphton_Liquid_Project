<section class="reviews-section">
  <div class="reviews-container">
    
    <h2 class="section-title">{{ section.settings.heading }}</h2>

    <div class="reviews-window" id="reviewsWindow">
      <div class="reviews-grid" id="reviewsTrack">

        {% for block in section.blocks %}
          <div class="review-card" {{ block.shopify_attributes }}>
            
            <div class="stars">{{ block.settings.stars }}</div>

            <h4 class="review-headline">
              {{ block.settings.title }}
            </h4>

            <p class="review-body">
              {{ block.settings.description }}
            </p>

            <p class="review-author">
              {{ block.settings.author }}
            </p>

          </div>
        {% endfor %}

      </div>
    </div>

    <!-- DOTS (static, JS controlled) -->
    <div class="slider-dots" id="reviewDots">
      {% for block in section.blocks %}
        <span class="dot {% if forloop.first %}active{% endif %}"></span>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Thousands of 5 Star Reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "text",
          "id": "stars",
          "label": "Stars",
          "default": "★★★★★"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "Amazing Coffee"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Review Description",
          "default": "This coffee is absolutely amazing!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "John D."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}