<section class="custom-product">

  <div class="product-container">

    <!-- LEFT IMAGE -->
    <div class="product-image">
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
    </div>

    <!-- RIGHT CONTENT -->
    <div class="product-info">

      <h1>{{ product.title }}</h1>

      <p class="price">{{ product.price | money }}</p>

      <!-- TASTING NOTES -->
      <p><strong>Tasting Notes:</strong> {{ product.description }}</p>

      <!-- VARIANTS (Weight, Roast etc) -->
      {% for option in product.options_with_values %}
        <label>{{ option.name }}</label>
        <select name="options[{{ option.name }}]">
          {% for value in option.values %}
            <option>{{ value }}</option>
          {% endfor %}
        </select>
      {% endfor %}

      <!-- ADD TO CART -->
     <form method="post" action="/cart/add" class="product-form" id="product-form">

  <input type="hidden" name="id" value="{{ product.variants.first.id }}">

  <!-- QUANTITY -->
  <div class="quantity">
    <button type="button" onclick="changeQty(-1)">-</button>
    <input type="number" name="quantity" value="1" id="qty">
    <button type="button" onclick="changeQty(1)">+</button>
  </div>

  <button type="submit" class="add-to-cart">
    Add to cart
  </button>

</form>

    </div>

  </div>

</section>

<script>
function changeQty(val){
  let qty = document.getElementById('qty');
  let current = parseInt(qty.value);
  if(current + val >= 1){
    qty.value = current + val;
  }
}
</script>
<section>
  <script>
document.getElementById('product-form').addEventListener('submit', function(e){
    e.preventDefault();

    const formData = new FormData(this);

    fetch('/cart/add.js', {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        openCart();
        loadCart(); // refresh cart
    });
});

function openCart(){
    document.getElementById('cartDrawer').classList.add('active');
}

function closeCart(){
    document.getElementById('cartDrawer').classList.remove('active');
}

// Load Updated Cart
function loadCart(){
    fetch('/cart.js')
    .then(res => res.json())
    .then(cart => {
        const container = document.getElementById('cartItems');
        container.innerHTML = '';

        cart.items.forEach(item => {
            const productDiv = document.createElement('div');
            productDiv.className = 'cart-item';
            productDiv.innerHTML = `
                <img src="${item.image}" alt="${item.title}" width="60" height="60"/>
                <div class="item-info">
                    <p>${item.title}</p>
                    <p>
                      <button class="decrease-qty" data-key="${item.key}">-</button>
                      ${item.quantity}
                      <button class="increase-qty" data-key="${item.key}">+</button>
                    </p>
                    <p>Price: Rs.${(item.price/100).toFixed(2)}</p>
                    <button class="remove-item" data-key="${item.key}">Remove</button>
                </div>
            `;
            container.appendChild(productDiv);
        });

        // Update total
        const totalContainer = document.getElementById('cartTotal');
        if(totalContainer){
            totalContainer.innerText = `Rs.${(cart.total_price/100).toFixed(2)}`;
        }

        // Add quantity and remove functionality
        document.querySelectorAll('.increase-qty').forEach(btn => {
            btn.addEventListener('click', () => updateQuantity(btn.dataset.key, 1));
        });
        document.querySelectorAll('.decrease-qty').forEach(btn => {
            btn.addEventListener('click', () => updateQuantity(btn.dataset.key, -1));
        });
        document.querySelectorAll('.remove-item').forEach(btn => {
            btn.addEventListener('click', () => removeItem(btn.dataset.key));
        });
    });
}

// Update quantity
function updateQuantity(key, change){
    fetch('/cart/change.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({line: key, quantity: change})
    }).then(() => loadCart());
}

// Remove item
function removeItem(key){
    fetch('/cart/change.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({line: key, quantity: 0})
    }).then(() => loadCart());
}
</script>
</section>